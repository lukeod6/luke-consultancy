---
import { siteConfig } from '../config/site';
---

<section class="relative overflow-hidden">
  <div class="atmosphere" aria-hidden="true">
    <div class="atmosphere__orb atmosphere__orb--a"></div>
    <div class="atmosphere__orb atmosphere__orb--b"></div>
    <div class="atmosphere__grid"></div>
  </div>

  <div class="container-full relative min-h-[min(88vh,52rem)] py-24 md:flex md:items-end md:py-28 lg:py-32">
    <div class="hero-intro max-w-hero min-w-0 pb-4">
      <p class="hero-brand">SignalFormation</p>
      <h1 class="mt-5 text-display-lg text-balance">Make AI earn its keep.</h1>
      <p class="mt-6 max-w-[38rem] text-lead text-muted">
        SignalFormation helps established SMEs assess existing AI expenditure, identify what is
        blocking adoption and turn viable initiatives into measurable operational improvements.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a
          href={siteConfig.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Book a 30-minute discussion
        </a>
        <a href="#approach" class="btn-secondary">See how the review works</a>
      </div>
    </div>
  </div>
</section>
