---
import { siteConfig } from '../config/site';
---

<section class="container-full pb-10 pt-24 md:pb-12 md:pt-28 lg:pt-32">
  <div class="grid items-end gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-12">
    <div data-reveal data-reveal-delay="1" class="reveal-sequence max-w-hero">
      <h1 class="text-display-lg text-balance">Make AI earn its keep.</h1>
      <p class="mt-6 max-w-[620px] text-lead text-muted">
        SignalFormation helps established SMEs assess existing AI expenditure, identify what is
        blocking adoption and turn viable initiatives into measurable operational improvements.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={siteConfig.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Book a 30-minute discussion
        </a>
        <a href="#approach" class="btn-secondary">See how the review works</a>
      </div>
      <p class="mt-5 text-[0.9375rem] text-muted md:text-base">
        <a
          href="#about"
          class="font-semibold text-ink underline underline-offset-4 transition hover:text-muted focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
        >
          Led directly by Luke Strugnell O'Donnell.
        </a>
      </p>
    </div>

    <div data-reveal data-reveal-delay="2" class="reveal-sequence panel relative p-6 md:p-8">
      <article>
        <p class="label">Offer</p>
        <h2 class="mt-3 font-display text-3xl font-normal tracking-tight md:text-[2.35rem]">
          AI Value Recovery Review
        </h2>

        <div
          class="mt-6 grid gap-3 rounded-2xl border border-border/80 bg-surface-soft/70 p-4 sm:grid-cols-3"
        >
          <div class="rounded-xl bg-white/80 px-3 py-3 text-center sm:text-left">
            <p class="text-[0.8125rem] font-semibold uppercase tracking-wider text-muted">Duration</p>
            <p class="mt-1 text-[0.9375rem] font-semibold text-ink md:text-base">7–10 working days</p>
          </div>
          <div class="rounded-xl bg-white/80 px-3 py-3 text-center sm:text-left">
            <p class="text-[0.8125rem] font-semibold uppercase tracking-wider text-muted">Investment</p>
            <p class="mt-1 text-[0.9375rem] font-semibold text-ink md:text-base">From £2,500</p>
          </div>
          <div class="rounded-xl bg-white/80 px-3 py-3 text-center sm:text-left">
            <p class="text-[0.8125rem] font-semibold uppercase tracking-wider text-muted">Scope</p>
            <p class="mt-1 text-[0.9375rem] font-semibold text-ink md:text-base">Up to 3 workflows</p>
          </div>
        </div>

        <ul class="mt-5 space-y-2.5 text-[0.9375rem] leading-relaxed text-muted md:text-base">
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            <span>Up to 5 stakeholder interviews</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            <span>Fixed-scope remote engagement</span>
          </li>
        </ul>

        <p class="mt-6 border-t border-border/70 pt-5 text-base font-semibold leading-snug text-ink md:text-lg">
          Stop, repair, consolidate or expand.
        </p>
      </article>
    </div>
  </div>

  <ul
    data-reveal
    data-reveal-delay="3"
    class="reveal-sequence mt-10 grid gap-3 border-t border-border/60 pt-8 text-[0.9375rem] text-muted sm:grid-cols-2 lg:flex lg:flex-nowrap lg:justify-between lg:gap-6 md:text-base"
    aria-label="Engagement principles"
  >
    <li class="flex items-start gap-2.5">
      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
      <span>Founder-led throughout</span>
    </li>
    <li class="flex items-start gap-2.5">
      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
      <span>Independent of software vendors</span>
    </li>
    <li class="flex items-start gap-2.5">
      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
      <span>Fixed-scope engagements</span>
    </li>
    <li class="flex items-start gap-2.5">
      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
      <span>Remote delivery across the globe</span>
    </li>
  </ul>
</section>
