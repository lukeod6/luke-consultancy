---
import { siteConfig } from '../config/site';
---

<section class="container-full pb-10 pt-24 md:pb-12 md:pt-28 lg:pt-32">
  <div class="grid items-end gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-12">
    <div data-reveal data-reveal-delay="1" class="reveal-sequence max-w-hero">
      <h1 class="text-display-lg text-balance">Make AI earn its keep.</h1>
      <p class="mt-6 max-w-[620px] text-lead text-muted">
        SignalFormation helps established SMEs assess existing AI expenditure, identify what is
        blocking adoption and turn viable initiatives into measurable operational improvements.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={siteConfig.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Book a 30-minute discussion
        </a>
        <a href="#approach" class="btn-secondary">See how the review works</a>
      </div>
      <p class="mt-5 text-[0.9375rem] text-muted md:text-base">
        <a
          href="#about"
          class="font-semibold text-ink underline underline-offset-4 transition hover:text-muted focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
        >
          Led directly by Luke Strugnell O'Donnell.
        </a>
      </p>
    </div>

    <div data-reveal data-reveal-delay="2" class="reveal-sequence panel relative p-6 md:p-8">
      <article>
        <p class="label-accent">Offer</p>
        <h2 class="mt-3 font-display text-3xl font-normal tracking-tight md:text-[2.35rem]">
          AI Value Recovery Review
        </h2>

        <dl
          class="mt-6 divide-y divide-border/60 rounded-2xl border border-border/80 bg-surface-soft/70 px-4"
        >
          <div class="flex items-baseline justify-between gap-4 py-3">
            <dt class="text-[0.8125rem] font-semibold uppercase tracking-wider text-muted">
              Duration
            </dt>
            <dd class="text-[0.9375rem] font-semibold text-ink md:text-base">7–10 working days</dd>
          </div>
          <div class="flex items-baseline justify-between gap-4 py-3">
            <dt class="text-[0.8125rem] font-semibold uppercase tracking-wider text-muted">
              Investment
            </dt>
            <dd class="text-[0.9375rem] font-semibold text-accent md:text-base">From £2,500</dd>
          </div>
          <div class="flex items-baseline justify-between gap-4 py-3">
            <dt class="text-[0.8125rem] font-semibold uppercase tracking-wider text-muted">Scope</dt>
            <dd class="text-[0.9375rem] font-semibold text-ink md:text-base">Up to 3 workflows</dd>
          </div>
        </dl>

        <ul class="list-marked mt-5 space-y-2.5 text-[0.9375rem] leading-relaxed text-muted md:text-base">
          <li>Up to 5 stakeholder interviews</li>
          <li>Fixed-scope remote engagement</li>
        </ul>

        <p class="mt-6 border-t border-border/70 pt-5 text-base font-semibold leading-snug text-ink md:text-lg">
          Stop, repair, consolidate or expand.
        </p>
      </article>
    </div>
  </div>

  <ul
    data-reveal
    data-reveal-delay="3"
    class="list-marked reveal-sequence mt-10 grid gap-3 border-t border-border/60 pt-8 text-[0.9375rem] text-muted sm:grid-cols-2 lg:flex lg:flex-nowrap lg:justify-between lg:gap-6 md:text-base"
    aria-label="Engagement principles"
  >
    <li>Founder-led throughout</li>
    <li>Independent of software vendors</li>
    <li>Fixed-scope engagements</li>
    <li>Remote delivery across the globe</li>
  </ul>
</section>
