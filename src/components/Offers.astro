          </p>
          <p class="mt-5 text-[0.9375rem] leading-[1.65] text-muted md:text-base">
            Where the review identifies a credible opportunity, SignalFormation improves one tightly
            defined workflow and measures the result against an agreed operational baseline.
          </p>
        </div>

        <div class="border-t border-border pt-8 md:border-l md:border-t-0 md:pl-12 md:pt-0">
          <p class="stage-num">03 · Oversee</p>
          <h3 class="mt-3 text-xl font-semibold tracking-[-0.02em]">Independent Oversight</h3>
          <p class="mt-5 text-[0.9375rem] leading-[1.65] text-muted md:text-base">
            SignalFormation can challenge vendors, track benefits and report to leadership without
            replacing the existing IT provider or implementation partner.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  (() => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const panels = document.querySelectorAll('.stage-panel');
    if (!panels.length) return;
    if (reduced) {
      panels.forEach((el) => el.classList.add('is-in'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
    );
    panels.forEach((el) => io.observe(el));
  })();
</script>
