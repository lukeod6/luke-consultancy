---
import { siteConfig } from '../config/site';
import Logo from './Logo.astro';

const showLinkedIn = Boolean(siteConfig.linkedInUrl);
---

<footer class="border-t border-border bg-paper">
  <div class="container-full flex flex-col gap-6 py-10 md:flex-row md:items-end md:justify-between md:py-12">
    <div>
      <a
        href="#main"
        class="inline-block focus-visible:outline-2 focus-visible:outline-[var(--color-focus)] focus-visible:outline-offset-2"
      >
        <Logo variant="horizontal" class="h-7 md:h-8" />
      </a>
      <p class="mt-3 max-w-sm text-sm text-muted">
        © 2026 SignalFormation. AI investment review for established SMEs.
      </p>
    </div>

    <p class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted">
      <a
        href={`mailto:${siteConfig.email}`}
        class="font-semibold text-ink underline underline-offset-4 hover:text-accent focus-visible:outline-2 focus-visible:outline-[var(--color-focus)] focus-visible:outline-offset-2"
        >{siteConfig.email}</a
      >
      {
        showLinkedIn && (
          <>
            <span aria-hidden="true">·</span>
            <a
              href={siteConfig.linkedInUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-ink underline underline-offset-4 hover:text-accent focus-visible:outline-2 focus-visible:outline-[var(--color-focus)] focus-visible:outline-offset-2"
            >
              LinkedIn
            </a>
          </>
        )
      }
    </p>
  </div>
</footer>
