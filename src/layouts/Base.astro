---
import '../styles/global.css';
import { siteConfig } from '../config/site';

const { title, description, ogImage = '/brand/signalformation-favicon.png' } = Astro.props;
// Optional: add a dedicated /public/og-image.png and pass ogImage="/og-image.png".
const canonical = new URL(Astro.url.pathname, Astro.site);
const linkedInSameAs = siteConfig.linkedInUrl ? [siteConfig.linkedInUrl] : [];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&display=swap"
    />

    <meta name="theme-color" content="#2F6F5E" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: "Luke Strugnell O'Donnell",
        jobTitle: 'AI Value Recovery Consultant',
        description:
          'Independent, founder-led consultancy helping UK SMEs assess existing AI expenditure, repair stalled initiatives and produce measurable operational value.',
        url: Astro.site?.toString(),
        email: siteConfig.email.includes('TODO') ? undefined : siteConfig.email,
        sameAs: linkedInSameAs,
        alumniOf: [
          { '@type': 'Organization', name: 'KnownOrigin' },
          { '@type': 'Organization', name: 'eBay' },
        ],
        worksFor: {
          '@type': 'Organization',
          name: siteConfig.siteName,
          description:
            'Independent AI value recovery consultancy for established UK SMEs.',
        },
      })}
    />

    <script
      is:inline
      defer
      data-domain="signalformation.com"
      src="https://plausible.io/js/script.js"
    ></script>
  </head>
  <body>
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 bg-surface-soft/45"></div>
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 -z-10 opacity-50 ambient-grid [mask-image:radial-gradient(circle_at_center,black_20%,transparent_75%)]"
    ></div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[820px] ambient-wash"></div>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:rounded focus:bg-ink focus:px-3 focus:py-2 focus:text-paper"
      >Skip to content</a
    >
    <slot />
    <script is:inline>
      (() => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const sections = document.querySelectorAll('[data-reveal]');
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
        );
        sections.forEach((section) => observer.observe(section));
      })();
    </script>
  </body>
</html>
