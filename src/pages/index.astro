---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Audience from '../components/Audience.astro';
import Problem from '../components/Problem.astro';
import Offers from '../components/Offers.astro';
import ValueFramework from '../components/ValueFramework.astro';
import About from '../components/About.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="SignalFormation | Recover Value From Underperforming AI Investments"
  description="SignalFormation reviews underperforming AI spend for established UK SMEs and turns the evidence into clear commercial decisions."
  ogImage="/luke-and-deer.png"
>
  <Nav />
  <main id="main">
    <Hero />
    <Problem />
    <Offers />
    <ValueFramework />
    <Audience />
    <About />
    <FAQ />
    <Contact />
  </main>
  <Footer />
</Base>
